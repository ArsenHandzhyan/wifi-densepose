# Copy this file to `.env` for local development.
# `.env` is gitignored and may contain your real local secrets.

ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-dev-secret

POSTGRES_DB=wifi_densepose
POSTGRES_USER=wifi_user
POSTGRES_PASSWORD=change-me-postgres-password
DATABASE_URL=postgresql://wifi_user:change-me-postgres-password@postgres:5432/wifi_densepose

REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:change-me-redis-password@redis:6379/0
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password

ENABLE_AUTHENTICATION=false
ENABLE_RATE_LIMITING=false
ENABLE_REAL_TIME_PROCESSING=true

HA_URL=http://localhost:8123
HA_TOKEN=
FP2_ENABLED=true
FP2_ENTITY_ID=binary_sensor.aqara_fp2
BACKEND_BEARER_TOKEN=
ROUTER_SSH_USERNAME=admin
ROUTER_SSH_PASSWORD=

# Optional local integrations
AQARA_EMAIL=
AQARA_PASSWORD=
AQARA_REGION=europe
AQARA_API_DOMAIN=
AQARA_APP_ID=
AQARA_APP_KEY=
AQARA_KEY_ID=
AQARA_ACCESS_TOKEN=
AQARA_REFRESH_TOKEN=

SMARTTHINGS_TOKEN=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pFZP5JQG7iQjIQuC4Bku
CSI_CONTINUOUS_RECORDING_ENABLED=false
CSI_CONTINUOUS_RECORDING_CHUNK_SEC=60
CSI_CONTINUOUS_RECORDING_LABEL_PREFIX=continuous_signal_archive
CSI_CONTINUOUS_RECORDING_MOTION_TYPE=continuous_archive
CSI_CONTINUOUS_RECORDING_NOTES=Automatic always-on CSI archive
